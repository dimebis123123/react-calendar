{
	"compilerOptions": {
		"module": "nodenext",
		"rootDir": "./src",
		"outDir": "./dist",
		"target": "esnext",
		"types": ["node"],

		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		"strict": true,
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	}
}
